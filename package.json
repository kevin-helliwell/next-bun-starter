{
  "name": "my-app",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "env_setup": "bash env_setup.sh",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:run": "bunx cypress run",
    "test:e2e": "bunx cypress open",
    "lint": "eslint . --cache",
    "pg:start": "docker compose -f compose.local.yml up",
    "pg:stop": "docker compose -f compose.local.yml down",
    "db:migrate:dev": "bunx prisma migrate dev",
    "db:migrate:reset": "bunx prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "vercel-build": "prisma generate && next build",
    "format": "prettier --log-level warn --write \"**/*.{ts,tsx,css,md}\"",
    "check:ci": "prettier --log-level warn --check \"**/*.{ts,tsx,css,md}\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.3",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@sentry/nextjs": "^10.28.0",
    "next": "^16.2.0",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.3.0",
    "superjson": "^2.2.1",
    "svix": "^1.40.0",
    "ts-pattern": "^5.9.0",
    "tsx": "^4.21.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/cypress": "^10.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.4.3",
    "@types/node": "^22.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.5",
    "autoprefixer": "^10.4.16",
    "cypress": "^14.5.0",
    "daisyui": "^4.12.14",
    "dotenv": "^17.2.3",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^4.1.0",
    "fallow": "^2.97.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "overrides": {
    "@types/pg": "$@types/pg"
  }
}
