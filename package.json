{
  "name": "my-app",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "env_setup": "bash env_setup.sh",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:run": "bunx cypress run",
    "test:e2e": "bunx cypress open",
    "lint": "eslint . --cache",
    "pg:start": "docker compose -f compose.local.yml up",
    "pg:stop": "docker compose -f compose.local.yml down",
    "db:migrate:dev": "bunx prisma migrate dev",
    "db:migrate:reset": "bunx prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "vercel-build": "prisma generate && next build",
    "format": "prettier --log-level warn --write \"**/*.{ts,tsx,css,md}\"",
    "check:ci": "prettier --log-level warn --check \"**/*.{ts,tsx,css,md}\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.59.0",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "superjson": "^2.2.6",
    "svix": "^1.96.0",
    "ts-pattern": "^5.9.0",
    "tsx": "^4.22.4",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@clerk/testing": "^2.1.5",
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.31",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.5.0",
    "cypress": "^14.5.4",
    "daisyui": "^4.12.24",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^4.3.0",
    "fallow": "^2.101.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "@types/pg": "$@types/pg"
  }
}
