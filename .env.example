# Copy to .env and fill in values for local development.

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/myapp

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
WEBHOOK_SECRET=

# Optional: base URL for local dev
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Sentry — https://sentry.io
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional: transactional email — https://resend.com
RESEND_API_KEY=
